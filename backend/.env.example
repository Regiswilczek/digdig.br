# Supabase
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres
SUPABASE_JWT_SECRET=your-legacy-hs256-jwt-secret
SUPABASE_URL=https://[project].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Redis (Railway)
REDIS_URL=redis://localhost:6379/0

# Claude API
CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
ANTHROPIC_API_KEY=sk-ant-...

# Mercado Pago
MERCADOPAGO_PUBLIC_KEY=TEST-...
MERCADOPAGO_ACCESS_TOKEN=TEST-...
# OBRIGATÓRIO em produção — secret HMAC SHA-256 configurado no painel do MP.
# Sem ele, validate_production_secrets bloqueia o boot da API.
MERCADOPAGO_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=re_...
RESEND_FROM=noreply@digdig.com.br

# App
ENVIRONMENT=development
SENTRY_DSN=
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
# Lista de emails admin separados por vírgula. Frontend precisa do mesmo
# valor em VITE_ADMIN_EMAILS no .env da raiz para a UX bater com o backend.
ADMIN_EMAILS=regisalessander@gmail.com
# OBRIGATÓRIO em produção — deve ser o mesmo valor configurado no webhook genérico
# Gerar: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=
